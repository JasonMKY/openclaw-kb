# ── Required ──────────────────────────────────────────────────────────────────

# Your OpenAI API key (used for embeddings + RAG)
OPENAI_API_KEY=sk-...

# Your Pinecone API key
PINECONE_API_KEY=pcsk_...


# ── Pinecone Config ───────────────────────────────────────────────────────────

# Name of the Pinecone index (auto-created on first run)
PINECONE_INDEX=openclaw-kb

# Cloud provider for serverless index: aws | gcp | azure
PINECONE_CLOUD=aws

# Region for the serverless index
PINECONE_REGION=us-east-1


# ── Embedding Config ──────────────────────────────────────────────────────────

# OpenAI embedding model (1536-dim)
EMBEDDING_MODEL=text-embedding-3-small

# Max tokens per chunk (400 recommended)
MAX_CHUNK_TOKENS=400

# Overlap tokens between chunks (50 recommended)
CHUNK_OVERLAP_TOKENS=50


# ── RAG Config ────────────────────────────────────────────────────────────────

# Model used to generate answers
RAG_MODEL=gpt-4o-mini

# Max tokens in the generated answer
RAG_MAX_TOKENS=1024


# ── Supabase (KBHub) ─────────────────────────────────────────────────────────

# Your Supabase project URL
SUPABASE_URL=https://nmootmadqhjiejxeiyqh.supabase.co

# Supabase anonymous/public key (safe to expose — RLS protects data)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5tb290bWFkcWhqaWVqeGVpeXFoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI0OTc5NzIsImV4cCI6MjA4ODA3Mzk3Mn0.bU1I5TX-PEjDRw7OILEt30dh6Vhb0dC6t8sLo7ceDgI


# ── Stripe (Payments) ─────────────────────────────────────────────────────────

# Stripe secret key (server-side only — never expose)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Server-only: copy "service_role" secret from Dashboard → Project Settings → API.
# Do NOT paste SUPABASE_ANON_KEY here — Stripe/payments need the service_role JWT.
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ── Contact Form (Resend) ─────────────────────────────────────────────────────

# Resend API key (https://resend.com/api-keys — free tier: 100 emails/day)
RESEND_API_KEY=re_...

# Where contact form submissions are sent
CONTACT_TO_EMAIL=support@clawditnow.com

# "From" address (must be a verified domain in Resend)
CONTACT_FROM_EMAIL=noreply@clawditnow.com


# ── OpenClaw Skill ────────────────────────────────────────────────────────────

# URL where the KB API is accessible from your OpenClaw agent
KB_API_URL=http://localhost:8000
